; test_m66_m68.ngc -- Experiment 1 & 2: M66 digital blocking handshake validation
;
; Uses digital slot 0 (P0):
;   M64/M65 P0  --> motion.digital-out-00  (remap signals fatc)
;   M66 P0      <-- motion.digital-in-00   (fatc signals remap)
;
; HOW TO RUN: Load this file and cycle-start (machine must be ON and homed).
;
; EXPERIMENT 1 (success path):
;   While blocked at M66 L1, open a terminal and run:
;     halcmd setp motion.digital-in-00 1
;   Expected: resumes, pin reads 1, RESULT: SUCCESS
;
; EXPERIMENT 2 (timeout path):
;   Don't set the pin -- let the 8-second timeout expire.
;   Expected: resumes, pin reads 0, RESULT: TIMED OUT
;
; After each run, reset:  halcmd setp motion.digital-in-00 0

(DEBUG, === M66 digital handshake test starting ===)

; Baseline L0 immediate read with pin known low
M66 P0 L0 Q0
#100 = #<_value>
(DEBUG, L0 with in-00=0: _value=#100  expected 0.0)

; Drive digital-out-00 high immediately M64 = immediate not queued
M64 P0
(DEBUG, M64 P0 sent -- motion.digital-out-00 should be 1 in halshow)

; L0 immediate read with in-00 still low out-00 not wired to in-00
M66 P0 L0 Q0
#100 = #<_value>
(DEBUG, L0 with in-00 still 0: _value=#100  expected 0.0)

; L1 blocking wait
(DEBUG, Blocking on M66 P0 L1 Q8 -- run: halcmd setp motion.digital-in-00 1)
M66 P0 L1 Q8
#100 = #<_value>
#101 = #<_hal[motion.digital-in-00]>
(DEBUG, After M66 L1: _value=#100  hal-pin-direct=#101)

o100 if [#101 GT 0]
    (DEBUG, RESULT: SUCCESS -- pin went high)
o100 else
    (DEBUG, RESULT: TIMED OUT -- pin still low)
o100 endif

(DEBUG, _value=1 on success -1 on timeout per docs if always 0 use hal-pin read)

; Clear outputs
M65 P0
(DEBUG, === test complete ===)
M2
