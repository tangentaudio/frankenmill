#!/usr/bin/env python3
"""M103 — Z_CLEAR.
Tells fatc Z has retracted; fatc advances sequence.
After stow: blocks until load carousel extended (READY_FOR_Z).
After load: blocks until carousel retracted (COMPLETE).
Exit 0 = ok; exit 1 = error.
"""
import json
import os
import socket
import sys

SOCK_PATH = os.environ.get('FATC_SOCKET', '/tmp/fatc.sock')

def ipc(cmd, **kwargs):
    msg = {'cmd': cmd, **kwargs}
    with socket.socket(socket.AF_UNIX) as s:
        s.settimeout(120.0)
        s.connect(SOCK_PATH)
        s.sendall(json.dumps(msg).encode() + b'\n')
        buf = b''
        while b'\n' not in buf:
            chunk = s.recv(4096)
            if not chunk:
                raise IOError('connection closed before response')
            buf += chunk
        return json.loads(buf.split(b'\n')[0])

def main():
    try:
        resp = ipc('Z_CLEAR')
    except Exception as exc:
        print(f'M103 error: {exc}', file=sys.stderr)
        sys.exit(1)
    if not resp.get('ok'):
        print(f"M103 failed: {resp.get('error', 'unknown')}", file=sys.stderr)
        sys.exit(1)

main()
