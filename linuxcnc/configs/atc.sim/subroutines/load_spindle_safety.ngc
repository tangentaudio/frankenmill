; Load a specific tool into the spindle via the ATC carousel.
; Called from the "LOAD SPINDLE" button on the ATC tab.
; #1 = tool number (from the tool number entry field)

o<load_spindle_safety> sub
(PRINT, o<load_spindle_safety>)

#<load_spindle_tool_number> = #1

o100 if [#<load_spindle_tool_number> LE 0]
    (abort, Invalid tool number #<load_spindle_tool_number> -- must be > 0)
o100 endif

; Perform the full physical tool change via our M6 remap.
; toolchange.ngc handles: stow current tool (if any), rotate carousel,
; extend, drawbar open/close, retract -- all via fatc.
T#<load_spindle_tool_number> M6

G43 H#<load_spindle_tool_number>

o<load_spindle_safety> endsub

M2
