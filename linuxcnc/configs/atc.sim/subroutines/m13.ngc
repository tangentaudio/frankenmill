o<m13> sub

; Home the ATC carousel via fatc.
; M104 sends HOME to the fatc IPC socket and blocks until homing completes.
(PRINT, o<m13>)

(DEBUG, EVAL[vcp.getWidget{"dynatc"}.atc_message{"REFERENCING"}])

M104

(DEBUG, EVAL[vcp.getWidget{"dynatc"}.atc_message{}])

(PRINT, o<m13> endsub)
o<m13> endsub [1]

M2
